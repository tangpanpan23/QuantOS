# =============================================
# QuantSaaS 环境变量配置
# =============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# =============================================
# 应用基础配置
# =============================================
APP_NAME=api
APP_HOST=0.0.0.0
APP_PORT=8888
APP_ENV=dev              # dev | test | prod

# =============================================
# JWT 认证配置（生产环境务必修改！）
# =============================================
JWT_ACCESS_SECRET=your_super_secure_secret_key_at_least_32_chars
JWT_ACCESS_EXPIRE=86400  # Token 有效期（秒），默认 24 小时

# =============================================
# 数据库配置
# =============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=quantos
DB_CHARSET=utf8mb4
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=300

# =============================================
# Redis 配置
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_KEY_PREFIX=quantos
REDIS_PASSWORD=

# =============================================
# RPC 服务配置（当前为 stub，逐步启用）
# =============================================
NEWS_POLICY_ENGINE_ENDPOINT=localhost:8081
STRATEGY_WORKSHOP_ENDPOINT=localhost:8082
AI_ASSISTANT_ENDPOINT=localhost:8083
SMART_EXECUTION_ENDPOINT=localhost:8084
STOCK_DATA_ENDPOINT=localhost:8085
MARKET_ANALYSIS_ENDPOINT=localhost:8086
STRATEGY_ENDPOINT=localhost:8087
TRADING_ENDPOINT=localhost:8088
SPECIAL_ANALYSIS_ENDPOINT=localhost:8089

# =============================================
# 日志配置
# =============================================
LOG_LEVEL=info           # debug | info | warn | error
LOG_FORMAT=console       # console | json

# =============================================
# 链路追踪（可选）
# =============================================
JAEGER_ENDPOINT=http://localhost:14268/api/traces
TRACING_SAMPLER=1.0

# =============================================
# 安全配置
# =============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# =============================================
# 功能开关
# =============================================
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_CACHE=true
DEBUG_MODE=true
AUTO_MIGRATE=true
