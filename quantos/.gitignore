# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go build output
/bin/
/dist/
/build/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace file
go.work

# Environment variables
.env
.env.local
.env.*.local

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Database files
*.db
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
*.tmp

# Docker volumes
docker-data/

# Kubernetes secrets (should not be committed)
secrets/

# Build artifacts
target/

# Node modules (if any frontend code)
node_modules/

# Coverage reports
coverage.html
coverage.xml

# API documentation
docs/api/

# SSL certificates
*.pem
*.key
*.crt

# Backup files
*.bak
*.backup

# Cache directories
.cache/
.tmp/
